{
  "manifest_version": 3,
  "name": "道·Devin 网页端 SP 注入器 (印88)",
  "short_name": "道·Devin SP",
  "version": "1.0.0",
  "description": "反者道之动 · 在 app.devin.ai 浏览器内 hook wss · 实现底层 system prompt 替换 (帛书《老子》/ 自定 / 6 策略) · 本地内统一管理",
  "author": "道 · 印88",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "道·Devin SP 注入器",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "*://app.devin.ai/*",
    "*://*.devin.ai/*",
    "http://127.0.0.1:11441/*",
    "http://localhost:11441/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://app.devin.ai/*",
        "*://*.devin.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": [
        "*://app.devin.ai/*",
        "*://*.devin.ai/*"
      ]
    }
  ]
}
