{
  "name": "dao-desktop",
  "displayName": "Devin Desktop",
  "description": "把官方 Devin Desktop 本体全量做成单一 VSIX 插件: 直接复用官方 codeium.windsurf(displayName \"Devin\")扩展本体 + Cascade 三模式面板(Cascade / Devin Cloud / Devin Local), 装进任意 VS Code 系 IDE 即得与官方一致的体感。与官方唯一差别: 从 IDE 本体降为一个插件, 功能 / 账号 / 模块 / 底层交互完全一致。",
  "version": "1.5.37",
  "publisher": "dao-agi",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "devin",
    "devin desktop",
    "cascade",
    "windsurf",
    "agent"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "description": "dao-desktop runs in all workspaces; Cascade 面板与官方本体不读写未信任工作区之外的内容"
    }
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dao-cascade",
          "title": "Devin Desktop",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "dao-cascade": [
        {
          "id": "dao.cascade",
          "name": "Cascade",
          "type": "webview"
        },
        {
          "id": "dao.unified",
          "name": "归一 · 插件本源",
          "type": "webview"
        },
        {
          "id": "dao.proxyPro",
          "name": "Proxy Pro",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "dao.cascade.open",
        "title": "Devin Desktop: 聚焦 Cascade 三模式面板",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "dao.cascade.agentBoard",
        "title": "Devin Desktop: Agent 看板 (Devin Cloud 会话 Board/List)"
      },
      {
        "command": "dao.cascade.openSettings",
        "title": "Devin Desktop: Devin Settings (设置整页)"
      },
      {
        "command": "dao.cascade.accountMenu",
        "title": "Devin Desktop: 账号菜单 (官方头像菜单同源)"
      },
      {
        "command": "dao.cascade.customizations",
        "title": "Devin Desktop: Customizations (Rules/Workflows/Skills/Memories)"
      },
      {
        "command": "dao.unified.open",
        "title": "Devin Desktop: 打开归一面板(主页/备份/MCP)"
      },
      {
        "command": "dao.cascade.newSession",
        "title": "Devin Desktop: 新建 Cascade 会话",
        "icon": "$(add)"
      },
      {
        "command": "dao.cascade.history",
        "title": "Devin Desktop: Cascade 历史会话",
        "icon": "$(history)"
      },
      {
        "command": "dao.cascade.backupAll",
        "title": "Devin Desktop: 备份全部 Cascade 对话"
      },
      {
        "command": "dao.cascade.deepwiki",
        "title": "Devin Desktop: DeepWiki 解释选中符号"
      },
      {
        "command": "dao.cascade.windowsAgent",
        "title": "Devin Desktop: Windows Agent 接入官方工具层 (MCP 注册)"
      },
      {
        "command": "dao.cascade.pcbAgent",
        "title": "Devin Desktop: ⚡ PCB · KiCad/嘉立创EDA (模块直开/工具层注册)"
      },
      {
        "command": "dao.cascade.fcAgent",
        "title": "Devin Desktop: 🧊 FreeCAD · 3D 建模 (模块直开/工具层注册)"
      },
      {
        "command": "dao.cascade.genCommit",
        "title": "Devin Desktop: ✨ 生成提交信息 (GenerateCommitMessage)",
        "icon": "$(sparkle)"
      },
      {
        "command": "dao.cascade.sendProblems",
        "title": "Devin Desktop: 把问题发送到 Cascade (Send problems)"
      },
      {
        "command": "dao.cascade.explainFix",
        "title": "Devin Desktop: 解释并修复 (Explain and Fix)"
      },
      {
        "command": "dao.cascade.login",
        "title": "Devin Desktop: Log in (登录 Devin 账号)"
      },
      {
        "command": "dao.cascade.logout",
        "title": "Devin Desktop: Log Out (登出 Devin 账号)"
      },
      {
        "command": "dao.cascade.addFile",
        "title": "Devin Desktop: Add Current File to Cascade (当前文件加入对话)"
      },
      {
        "command": "dao.cascade.createRule",
        "title": "Devin Desktop: Create New Rule (新建规则)"
      },
      {
        "command": "dao.cascade.createWorkflow",
        "title": "Devin Desktop: Create New Workflow (新建工作流)"
      },
      {
        "command": "dao.cascade.createGlobalWorkflow",
        "title": "Devin Desktop: Create New Global Workflow (新建全局工作流)"
      },
      {
        "command": "dao.cascade.openProfile",
        "title": "Devin Desktop: View Account (查看账户)"
      },
      {
        "command": "dao.cascade.openChangelog",
        "title": "Devin Desktop: Open Changelog (更新日志)"
      },
      {
        "command": "dao.cascade.toggleAgentWindow",
        "title": "Devin Desktop: Toggle Agent Window (Agent 模式 ↔ 编辑器模式)",
        "icon": "$(layout-panel)"
      },
      {
        "command": "dao.cascade.toggleModelSelector",
        "title": "Devin Desktop: Toggle Model Selector (模型选择器)"
      },
      {
        "command": "dao.cascade.switchToNextModel",
        "title": "Devin Desktop: Switch to Next Model (切下一模型)"
      },
      {
        "command": "dao.cascade.toggleWriteChatMode",
        "title": "Devin Desktop: Toggle Session Mode (Write/Chat/Plan 会话模式)"
      },
      {
        "command": "dao.cascade.openAgentPicker",
        "title": "Devin Desktop: Open Agent Picker (agent 选择器)"
      },
      {
        "command": "dao.cascade.inlineCommand",
        "title": "Devin Desktop: Inline Command (编辑器内联命令 · 就地编辑)"
      },
      {
        "command": "dao.cascade.acceptDiff",
        "title": "Devin Desktop: Accept Diff (接受当前 diff 块)"
      },
      {
        "command": "dao.cascade.rejectDiff",
        "title": "Devin Desktop: Reject Diff (拒绝当前 diff 块)"
      },
      {
        "command": "dao.cascade.acceptAllDiffs",
        "title": "Devin Desktop: Accept All Diffs (接受全部 diff)"
      },
      {
        "command": "dao.cascade.rejectAllDiffs",
        "title": "Devin Desktop: Reject All Diffs (拒绝全部 diff)"
      },
      {
        "command": "dao.cascade.cascadeBar",
        "title": "Devin Desktop: Cascade Bar (diff 操作条 · hunk 导航/接受/拒绝)",
        "icon": "$(diff)"
      },
      {
        "command": "dao.cascade.nextDiffHunk",
        "title": "Devin Desktop: Focus Next Diff Hunk (下一个 hunk)"
      },
      {
        "command": "dao.cascade.prevDiffHunk",
        "title": "Devin Desktop: Focus Previous Diff Hunk (上一个 hunk)"
      },
      {
        "command": "dao.cascade.acceptFocusedHunk",
        "title": "Devin Desktop: Accept Focused Hunk (接受当前 hunk)"
      },
      {
        "command": "dao.cascade.rejectFocusedHunk",
        "title": "Devin Desktop: Reject Focused Hunk (拒绝当前 hunk)"
      },
      {
        "command": "dao.cascade.acceptAllInFile",
        "title": "Devin Desktop: Accept All In File (接受本文件全部 diff)"
      },
      {
        "command": "dao.cascade.rejectAllInFile",
        "title": "Devin Desktop: Reject All In File (拒绝本文件全部 diff)"
      },
      {
        "command": "dao.cascade.importRulesFromCursor",
        "title": "Devin Desktop: Import Rules from Cursor (导入 Cursor 规则 → .windsurf/rules)"
      },
      {
        "command": "dao.cascade.openBrowser",
        "title": "Devin Desktop: Open Browser (官方 openBrowser 对位)"
      },
      {
        "command": "dao.cascade.lifeguardCheck",
        "title": "Devin Desktop: Lifeguard Check (检查当前变更 · 官方 Ctrl+U 对位)"
      },
      {
        "command": "dao.cascade.acpRegistry",
        "title": "Devin Desktop: ACP Registry (ACP 代理清单/连接 · 官方对位)"
      },
      {
        "command": "dao.cascade.refreshSessions",
        "title": "Devin Desktop: Refresh Sessions (重拉云端会话 · 跨端 pull-on-restart)"
      },
      {
        "command": "dao.cascade.refreshCustomizations",
        "title": "Devin Desktop: Refresh Rules/Workflows/Skills (官方 RefreshCustomization RPC)"
      },
      {
        "command": "dao.cascade.refreshMcp",
        "title": "Devin Desktop: Refresh MCP Servers (官方 RefreshMcpServers RPC)"
      },
      {
        "command": "dao.cascade.downloadDiagnostics",
        "title": "Devin Desktop: Download Diagnostics (官方直通/GetDebugDiagnostics 真源)"
      },
      {
        "command": "dao.cascade.applyOfficialTheme",
        "title": "Dao: 应用官方 Devin Desktop 主题(Devin Dark)",
        "category": "Devin Desktop"
      },
      {
        "command": "dao.cascade.openShell",
        "title": "归一外壳: 打开 /shell 单网页(浏览器)",
        "category": "Devin Desktop"
      }
    ],
    "keybindings": [
      {
        "command": "dao.cascade.open",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "!terminalFocus && !editorHasSelection"
      },
      {
        "command": "dao.cascade.newSession",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "!terminalFocus"
      },
      {
        "command": "dao.cascade.newSession",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "!terminalFocus"
      },
      {
        "command": "dao.cascade.addFile",
        "key": "ctrl+shift+8",
        "mac": "cmd+shift+8",
        "when": "editorTextFocus"
      },
      {
        "command": "dao.cascade.toggleModelSelector",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "!terminalFocus && !editorTextFocus"
      },
      {
        "command": "dao.cascade.switchToNextModel",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "!terminalFocus"
      },
      {
        "command": "dao.cascade.toggleWriteChatMode",
        "key": "ctrl+.",
        "mac": "cmd+.",
        "when": "!terminalFocus && !editorTextFocus"
      },
      {
        "command": "dao.cascade.openAgentPicker",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "!terminalFocus && !editorTextFocus"
      },
      {
        "command": "dao.cascade.inlineCommand",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      },
      {
        "command": "dao.cascade.nextDiffHunk",
        "key": "alt+j",
        "when": "editorTextFocus && config.dao.cascadeBar.keys"
      },
      {
        "command": "dao.cascade.prevDiffHunk",
        "key": "alt+k",
        "when": "editorTextFocus && config.dao.cascadeBar.keys"
      },
      {
        "command": "dao.cascade.acceptFocusedHunk",
        "key": "alt+enter",
        "when": "editorTextFocus && config.dao.cascadeBar.keys"
      },
      {
        "command": "dao.cascade.rejectFocusedHunk",
        "key": "alt+shift+backspace",
        "when": "editorTextFocus && config.dao.cascadeBar.keys"
      },
      {
        "command": "dao.cascade.acceptAllInFile",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && config.dao.cascadeBar.keys"
      },
      {
        "command": "dao.cascade.rejectAllInFile",
        "key": "shift+ctrl+backspace",
        "mac": "shift+cmd+backspace",
        "when": "editorTextFocus && config.dao.cascadeBar.keys"
      },
      {
        "command": "dao.cascade.lifeguardCheck",
        "key": "ctrl+u",
        "mac": "cmd+u",
        "when": "config.dao.cascadeBar.keys"
      },
      {
        "key": "alt+\\",
        "command": "editor.action.inlineSuggest.trigger",
        "when": "editorTextFocus && !editorHasSelection"
      },
      {
        "key": "ctrl+'",
        "command": "dao.cascade.openAgentPicker"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dao.cascade.newSession",
          "when": "view == dao.cascade",
          "group": "navigation@1"
        },
        {
          "command": "dao.cascade.history",
          "when": "view == dao.cascade",
          "group": "navigation@2"
        }
      ],
      "scm/title": [
        {
          "command": "dao.cascade.genCommit",
          "when": "scmProvider == git",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "dao.cascade.explainFix",
          "when": "editorTextFocus",
          "group": "1_modification@9"
        }
      ],
      "editor/title": [
        {
          "command": "dao.cascade.open",
          "group": "navigation@90"
        },
        {
          "command": "dao.cascade.cascadeBar",
          "group": "navigation@91"
        },
        {
          "command": "dao.cascade.toggleAgentWindow",
          "group": "navigation@92"
        }
      ]
    },
    "configuration": {
      "title": "Devin Desktop",
      "properties": {
        "dao.cascadeBar.keys": {
          "type": "boolean",
          "default": true,
          "description": "Cascade Bar 键位与官方一致(Alt+J/K · Alt+Enter · Ctrl+Enter 等)。关闭后仅保留命令面板/状态栏入口。"
        },
        "dao.localApi.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "激活即自启本地 HTTP API（端点全开放·后端打动一切）；端口与 token 落 ~/.dao/local-api.json（mode 600）。"
        },
        "dao.cascade.autoBackup": {
          "type": "boolean",
          "default": true,
          "description": "Cascade 对话自动备份：会话变更即增量导出轨迹转录到备份目录（与 dao-one 对话备份板块同源消费）。"
        },
        "dao.cascade.backupDir": {
          "type": "string",
          "default": "",
          "description": "Cascade 对话备份根目录；留空用 ~/.wam/conversation_backups（亦可经环境变量 DAO_CASCADE_BACKUP_DIR 重定向）。"
        },
        "dao.truthWatch.enabled": {
          "type": "boolean",
          "default": true,
          "description": "真源守望: 官方落盘真源(MCP/Rules/Workflows/Skills/记忆)变更即经官方 Refresh RPC 重读 — 跨 IDE 改动自动即见。"
        },
        "dao.cascade.autoRefreshMinutes": {
          "type": "number",
          "default": 0,
          "description": "自持 LS 周期性重启重拉云端会话真源的间隔(分钟, 0=关)。官方无跨端实时推送(R160/R168 实测), 该轮询为如实兜底; 共生官方 LS 不代杀。"
        }
      }
    },
    "themes": [
      {
        "id": "Devin Dark",
        "label": "Devin Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/windsurf-dark.json"
      },
      {
        "id": "Devin Light",
        "label": "Devin Light",
        "uiTheme": "vs",
        "path": "./themes/windsurf-light.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "**/mcp_config.json",
        "url": "./schemas/mcp_config.schema.json"
      },
      {
        "fileMatch": "**/acp/registry.json",
        "url": "./schemas/acp_registry.schema.json"
      }
    ],
    "languages": [
      {
        "id": "jsonc",
        "filenames": [
          "mcp_config.json"
        ]
      }
    ]
  },
  "scripts": {
    "build": "node build.js",
    "sync-official": "node scripts/sync-official.js",
    "package": "npx --yes @vscode/vsce package -o dao-desktop.vsix --allow-missing-repository --skip-license --allow-star-activation"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dao-genesis/windsurf-assistant.git",
    "directory": "plugins/dao-desktop"
  }
}
