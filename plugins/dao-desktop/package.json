{
  "name": "dao-desktop",
  "displayName": "Devin Desktop",
  "description": "把官方 Devin Desktop 本体全量做成单一 VSIX 插件: 直接复用官方 codeium.windsurf(displayName \"Devin\")扩展本体 + Cascade 三模式面板(Cascade / Devin Cloud / Devin Local), 装进任意 VS Code 系 IDE 即得与官方一致的体感。与官方唯一差别: 从 IDE 本体降为一个插件, 功能 / 账号 / 模块 / 底层交互完全一致。",
  "version": "1.0.0",
  "publisher": "dao-agi",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "devin",
    "devin desktop",
    "cascade",
    "windsurf",
    "agent"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "description": "dao-desktop runs in all workspaces; Cascade 面板与官方本体不读写未信任工作区之外的内容"
    }
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dao-cascade",
          "title": "Devin Desktop",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "dao-cascade": [
        {
          "id": "dao.cascade",
          "name": "Cascade · 三模式",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "dao.cascade.open",
        "title": "Devin Desktop: 聚焦 Cascade 三模式面板"
      },
      {
        "command": "dao.cascade.newSession",
        "title": "Devin Desktop: 新建 Cascade 会话",
        "icon": "$(add)"
      },
      {
        "command": "dao.cascade.history",
        "title": "Devin Desktop: Cascade 历史会话",
        "icon": "$(history)"
      },
      {
        "command": "dao.cascade.deepwiki",
        "title": "Devin Desktop: DeepWiki 解释选中符号"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dao.cascade.newSession",
          "when": "view == dao.cascade",
          "group": "navigation@1"
        },
        {
          "command": "dao.cascade.history",
          "when": "view == dao.cascade",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "node build.js",
    "package": "npx --yes @vscode/vsce package -o dao-desktop.vsix --allow-missing-repository --skip-license --allow-star-activation"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dao-devin/windsurf-assistant.git",
    "directory": "plugins/dao-desktop"
  }
}
