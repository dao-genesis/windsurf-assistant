{
	"name": "rt-flow",
	"displayName": "Runtime Flow",
	"description": "Runtime flow management · adaptive scheduling",
	"version": "2.6.8",
	"publisher": "devaid",
	"repository": {
		"type": "git",
		"url": "https://github.com/dao-genesis/windsurf-assistant.git",
		"directory": "wam-bundle"
	},
	"homepage": "https://github.com/dao-genesis/windsurf-assistant",
	"bugs": {
		"url": "https://github.com/dao-genesis/windsurf-assistant/issues"
	},
	"keywords": [
		"runtime",
		"flow",
		"scheduling",
		"adaptive",
		"management"
	],
	"license": "MIT",
	"icon": "media/icon.png",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"AI",
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "wam-container",
					"title": "RT Flow",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"wam-container": [
				{
					"id": "wam.panel",
					"name": "Manager",
					"type": "webview"
				}
			]
		},
		"commands": [
			{
				"command": "wam.openEditor",
				"title": "Open Panel",
				"category": "RT Flow"
			},
			{
				"command": "wam.status",
				"title": "Status",
				"category": "RT Flow"
			},
			{
				"command": "wam.switchAccount",
				"title": "Switch Account",
				"category": "RT Flow"
			},
			{
				"command": "wam.panicSwitch",
				"title": "Emergency Switch",
				"category": "RT Flow"
			},
			{
				"command": "wam.refreshAll",
				"title": "Refresh All",
				"category": "RT Flow"
			},
			{
				"command": "wam.addAccount",
				"title": "Add Account",
				"category": "RT Flow"
			},
			{
				"command": "wam.injectToken",
				"title": "Inject Token",
				"category": "RT Flow"
			},
			{
				"command": "wam.verifyAll",
				"title": "Verify & Clean",
				"category": "RT Flow"
			},
			{
				"command": "wam.scanExpiry",
				"title": "Scan Expiry",
				"category": "RT Flow"
			},
			{
				"command": "wam.healthCheck",
				"title": "Health Check",
				"category": "RT Flow"
			},
			{
				"command": "wam.clearBlacklist",
				"title": "Clear Blacklist",
				"category": "RT Flow"
			},
			{
				"command": "wam.clearAllInUse",
				"title": "Clear All In-Use Locks (v2.3.0)",
				"category": "RT Flow"
			},
			{
				"command": "wam.clearAllHealth",
				"title": "Clear All Health Data (v2.4.0)",
				"category": "RT Flow"
			},
			{
				"command": "wam.endpointHealth",
				"title": "Show Quota Endpoint Health (v2.4.0)",
				"category": "RT Flow"
			},
			{
				"command": "wam.toggleAutoRotate",
				"title": "Toggle Auto-Rotate",
				"category": "RT Flow"
			},
			{
				"command": "wam.show",
				"title": "Show Output Log",
				"category": "RT Flow"
			},
			{
				"command": "wam.setModeWam",
				"title": "WAM Mode",
				"category": "RT Flow"
			},
			{
				"command": "wam.setModeOfficial",
				"title": "Official Login Mode",
				"category": "RT Flow"
			}
		],
		"configuration": {
			"title": "RT Flow",
			"properties": {
				"wam.accountsFile": {
					"type": "string",
					"default": "",
					"description": "Account pool file path (empty = auto-detect)"
				},
				"wam.autoRotate": {
					"type": "boolean",
					"default": true,
					"description": "Auto-switch when quota drops below threshold"
				},
				"wam.autoSwitchThreshold": {
					"type": "number",
					"default": 5,
					"description": "Auto-switch threshold (%)"
				},
				"wam.scanIntervalMs": {
					"type": "number",
					"default": 60000,
					"description": "Quota scan interval (ms, min 30s)"
				},
				"wam.preferYi": {
					"type": "boolean",
					"default": false,
					"description": "Force clipboard injection path"
				},
				"wam.notifyLevel": {
					"type": "string",
					"enum": [
						"silent",
						"notify",
						"verbose"
					],
					"default": "notify",
					"description": "Notification level"
				},
				"wam.startupDelayMs": {
					"type": "number",
					"default": 3500,
					"description": "Startup delay before first auto-login (ms)"
				},
				"wam.invisible": {
					"type": "boolean",
					"default": false,
					"description": "Invisible mode — minimal UI + zero toast"
				},
				"wam.rotatePeriodMs": {
					"type": "number",
					"default": 0,
					"description": "Time rotation period (ms, 0=off)"
				},
				"wam.verify.parallel": {
					"type": "number",
					"default": 3,
					"description": "Batch verify parallelism (1-8)"
				},
				"wam.verify.gapMs": {
					"type": "number",
					"default": 250,
					"description": "Verify gap between completions (ms)"
				},
				"wam.verify.staleMin": {
					"type": "number",
					"default": 30,
					"description": "Skip recently verified accounts (min)"
				},
				"wam.autoVerifyOnStartupMs": {
					"type": "number",
					"default": 30000,
					"description": "Auto verify stale accounts after startup (ms, 0=off)"
				},
				"wam.autoVerifyPeriodMs": {
					"type": "number",
					"default": 1800000,
					"description": "Periodic verify interval (ms, 0=off)"
				},
				"wam.predictiveThreshold": {
					"type": "number",
					"default": 25,
					"description": "Pre-select candidate threshold (%)"
				},
				"wam.switchCooldownMs": {
					"type": "number",
					"default": 15000,
					"description": "Min interval between auto-switches (ms)"
				},
				"wam.waitResetHours": {
					"type": "number",
					"default": 3,
					"description": "Wait for reset when within N hours"
				},
				"wam.rotateOnEveryMessage": {
					"type": "boolean",
					"default": true,
					"description": "v2.3.0 直觉切号: 用户每发一条 Cascade 消息即切下一号 (反者道之动 · 默认开 · 与使用中🔒合带·极限分散使用)"
				},
				"wam.inUseLockMs": {
					"type": "number",
					"default": 120000,
					"description": "v2.3.0 使用中🔒: 切号成功后该号锁定 N ms · 锁期内自动切号不入选 · 手动切号不受影响 · 0=关 · 默认 120s"
				},
				"wam.perMessageDebounceMs": {
					"type": "number",
					"default": 4000,
					"description": "每消息切号防抖 (一轮多请求只算一次, ms)"
				},
				"wam.perMessageDelayMs": {
					"type": "number",
					"default": 1500,
					"description": "每消息切号延迟 (让当前消息先送出再切, ms)"
				},
				"wam.sendDetectSettleMs": {
					"type": "number",
					"default": 15000,
					"description": "v2.6.6 pb·settle 静默期 — 反者道之动 · 文件增长后静默此时长未再变 → AI 已停 → 切号 (ms)"
				},
				"wam.sendDetectAccumMin": {
					"type": "number",
					"default": 5120,
					"description": "v2.6.6 pb·settle 累积阈值 — settle 期内累积增量 ≥ 此值才切号 · 过滤 cascade 心跳/元数据小写 (bytes)"
				},
				"wam.sendDetectGrowMin": {
					"type": "number",
					"default": 30,
					"description": "v2.6.6 pb·settle 单次最小增量 — 低于此值不入累积 · 噪声过滤 (bytes)"
				},
				"wam.walDetect": {
					"type": "boolean",
					"default": true,
					"description": "v2.6.3 WAL 直达触发 — 监听 state.vscdb-wal 作为 Send 按鈕最底层信号源 (click Send 后 SQLite 同步写入·早于 AI 响应)"
				},
				"wam.walDetectSettleMs": {
					"type": "number",
					"default": 15000,
					"description": "v2.6.6 wal·settle 静默期 — 反者道之动 · WAL 增长后静默此时长未再变 → 切号 (ms)"
				},
				"wam.walDetectAccumMin": {
					"type": "number",
					"default": 10240,
					"description": "v2.6.6 wal·settle 累积阈值 — settle 期内 WAL 累积增量 ≥ 此值才切号 · 过滤 SQLite 心跳 (bytes)"
				},
				"wam.walDetectGrowMin": {
					"type": "number",
					"default": 1024,
					"description": "v2.6.3 WAL 单次最小增量 — SQLite WAL 帧 = pageSize(4096)+24B/帧 · 1024 可捕获任意有效写入 (bytes)"
				}
			}
		}
	}
}
